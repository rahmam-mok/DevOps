###############################################################################
# DEV environment
###############################################################################

aws_region  = "us-east-1"
environment = "dev"
identifier  = "oracle-app-dev"

# --- Existing networking (REPLACE with real IDs) ---------------------------
subnet_ids             = ["subnet-0dev1111111111111", "subnet-0dev2222222222222"]
vpc_security_group_ids = ["sg-0dev0000000000000"]

# --- Engine (single-tenant / non-CDB) --------------------------------------
engine                 = "oracle-se2"
engine_version         = "19.0.0.0.ru-2024-01.rur-2024-01.r1"
license_model          = "license-included"
parameter_group_family = "oracle-se2-19"
character_set_name     = "AL32UTF8"

# --- Sizing & storage ------------------------------------------------------
instance_class        = "db.t3.medium"
allocated_storage     = 50
max_allocated_storage = 100
storage_type          = "gp3"
storage_encrypted     = true

# --- Database --------------------------------------------------------------
db_name  = ""
username = ""
port     = 1521

# --- HA / backups / protection (relaxed for dev) ---------------------------
multi_az                = false
backup_retention_period = 1
deletion_protection     = false
skip_final_snapshot     = true
apply_immediately       = true

# --- Monitoring ------------------------------------------------------------
performance_insights_enabled    = true
monitoring_interval             = 0
enabled_cloudwatch_logs_exports = ["alert", "listener"]

# --- Parameters / options --------------------------------------------------
db_parameters = [
  { name = "open_cursors", value = "300" }
]

db_options = []

tags = {
  Environment = "dev"
  Application = "oracle-app"
  ManagedBy   = "terraform"
  CostCenter  = "engineering"
}


